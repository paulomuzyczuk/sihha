# Copy to .env.local and fill in real values. Never commit .env.local.

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=                   # public  — project API URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=              # public  — safe for browser use
SUPABASE_SERVICE_ROLE_KEY=                  # secret  — bypasses RLS; server-side only

# ── Auth ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=                       # public  — canonical origin, e.g. https://your-app.vercel.app

# ── Email (Gmail SMTP) ──────────────────────────────────────────────────────
GMAIL_USER=                                 # secret  — sender Gmail address
GMAIL_APP_PASSWORD=                         # secret  — Gmail App Password (not account password)
ADMIN_EMAIL=                                # secret  — receives access-request notifications
ALERT_EMAIL_ADMIN=                          # secret  — receives low-stock medication alerts
ALERT_EMAIL_THERAPIST_A=                    # secret  — alert recipient for therapist slot A
ALERT_EMAIL_THERAPIST_B=                    # secret  — alert recipient for therapist slot B
EMAIL_LOCALE=                               # public  — alert e-mail language: en (default) or pt

# ── Geolocation ─────────────────────────────────────────────────────────────
TARGET_LAT=                                 # secret  — zone 1 centre latitude
TARGET_LNG=                                 # secret  — zone 1 centre longitude
ALLOWED_RADIUS_METERS=                      # secret  — zone 1 acceptance radius in metres
DEBUG_LAT=                                  # secret  — zone 2 centre latitude (optional; omit in production)
DEBUG_LNG=                                  # secret  — zone 2 centre longitude (optional; omit in production)
DEBUG_RADIUS_METERS=                        # secret  — zone 2 acceptance radius in metres (optional; omit in production)

# ── Vercel Cron ─────────────────────────────────────────────────────────────
CRON_SECRET=                                # secret  — authorises calls to /api/cron/* from Vercel

# ── Rate limiting (Upstash Redis) ───────────────────────────────────────────
# Optional but RECOMMENDED in production: without these the rate limiter falls
# back to per-instance in-memory counters, which are ineffective across the
# multiple serverless instances Vercel runs. Set both to enable a shared limit.
UPSTASH_REDIS_REST_URL=                     # secret  — Upstash Redis REST URL
UPSTASH_REDIS_REST_TOKEN=                   # secret  — Upstash Redis REST token
