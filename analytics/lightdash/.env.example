# Copy to .env next to docker-compose.yml (never commit the copy).

# Password for Lightdash's OWN metadata Postgres (the `db` service) — pick
# anything, it is internal to the compose network.
LIGHTDASH_DB_PASSWORD=change-me

# Session/encryption secret — generate with: openssl rand -hex 32
LIGHTDASH_SECRET=change-me

# Where the browser reaches Lightdash (adjust if not localhost:8080)
SITE_URL=http://localhost:8080
